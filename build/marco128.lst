2152  C67A              ; ============================================================
2153  C67A              ; TILE COLLISION HELPERS
2154  C67A              ; ============================================================
2155  C67A
2156  C67A              ; GetTileAt: HL=world_pixel_x (16-bit), B=world_pixel_y → A=tile_id
2157  C67A              ; Fix 33: changed from C=pixel_x (8-bit) to HL=pixel_x (16-bit) so the full
2158  C67A              ; x coordinate is used. Tiles 16+ (x >= 256) were silently truncated before.
2159  C67A              ; Also pushes/pops BC so caller's B (pixel_y) survives — Fix31 changed
2160  C67A              ; the cache address to use BC which clobbered B, breaking cg_snap in CheckGround.
2161  C67A              GetTileAt:
2162  C67A                  ; Reads from level_map_cache in bank2 — no paging needed
2163  C67A E5               push hl
2164  C67B D5               push de
2165  C67C C5               push bc             ; preserve caller's B (pixel_y) — Fix 33
2166  C67D
2167  C67D                  ; Compute tile_x from 16-bit pixel_x in HL (0..1023):
2168  C67D                  ; tile_x = pixel_x / 16 = H*16 + L/16
2169  C67D 7D               ld a, l
2170  C67E 0F               rrca
2171  C67F 0F               rrca
2172  C680 0F               rrca
2173  C681 0F               rrca
2174  C682 E6 0F            and $0F             ; low 4 bits: L >> 4
2175  C684 5F               ld e, a
2176  C685 7C               ld a, h
2177  C686 E6 03            and $03             ; only bits[1:0] of H matter (pixel_x <= 1023)
2178  C688 07               rlca
2179  C689 07               rlca
2180  C68A 07               rlca
2181  C68B 07               rlca
2182  C68C E6 30            and $30             ; high 2 bits: H << 4
2183  C68E B3               or e
2184  C68F E6 3F            and $3F
2185  C691 5F               ld e, a             ; E = tile_x (0..63)
2186  C692
2187  C692 78               ld a, b
2188  C693 0F               rrca
2189  C694 0F               rrca
2190  C695 0F               rrca
2191  C696 0F               rrca
2192  C697 E6 0F            and $0F
2193  C699 57               ld d, a             ; tile_y (0..10)
2194  C69A
2195  C69A FE 0B            cp MAP_H
2196  C69C D2 B9 C6         jp nc, .gta_solid
2197  C69F 7B               ld a, e
2198  C6A0 FE 40            cp MAP_W
2199  C6A2 D2 B9 C6         jp nc, .gta_solid
2200  C6A5
2201  C6A5                  ; offset = tile_y * MAP_W + tile_x
2202  C6A5                  ; Fix 31: was 'ld de, level_map_cache / add hl, de / ld b,0 / ld c,e'
2203  C6A5                  ; but ld de overwrites E (tile_x), so ld c,e loaded $A3 (low byte of
2204  C6A5                  ; level_map_cache = $80A3) instead of tile_x. Every tile lookup was
2205  C6A5                  ; 161 bytes past the intended position, always past the end of the cache,
2206  C6A5                  ; reading random RAM. Ground tiles never detected → player fell through
2207  C6A5                  ; floor → screen_y ≥ 177 → DrawSprite wrote into attr/sysvar area → crash.
2208  C6A5                  ; Fix: use ld bc / add hl,bc which preserves DE (E still = tile_x).
2209  C6A5 26 00            ld h, 0
2210  C6A7 6A               ld l, d
2211  C6A8 29               add hl, hl
2212  C6A9 29               add hl, hl
2213  C6AA 29               add hl, hl
2214  C6AB 29               add hl, hl
2215  C6AC 29               add hl, hl
2216  C6AD 29               add hl, hl             ; hl = tile_y * 64  (MAP_W=64)
2217  C6AE 01 B5 80         ld bc, level_map_cache
2218  C6B1 09               add hl, bc             ; hl = level_map_cache + tile_y*64 (E still = tile_x)
2219  C6B2 06 00            ld b, 0
2220  C6B4 4B               ld c, e                ; tile_x — E intact because we used BC not DE above
2221  C6B5 09               add hl, bc
2222  C6B6 7E               ld a, (hl)
2223  C6B7 18 02            jr .gta_done
2224  C6B9
2225  C6B9              .gta_solid:
2226  C6B9 3E 01            ld a, TILE_GROUND
2227  C6BB              .gta_done:
