 938  BFD4              ; DrawCharXY trampoline — PINNED at $BFFD.
 939  BFD4              ; JP nn is 3 bytes: $BFFD/$BFFE/$BFFF — the last safe slot
 940  BFD4              ; entirely within bank2. Adding code above? Check for overlap.
 941  BFD4              ; ============================================================
 942  BFD4                  ORG $BFFD
 943  BFFD              DrawCharXY:
 944  BFFD C3 00 C0         jp DrawCharXY_Real
 945  C000
 946  C000              ; ============================================================
 947  C000              ; BANK 7 — CODE OVERFLOW ($C000-$FFFF when bank 7 paged)
 948  C000              ; Always paged during gameplay. Bank2 ($8000-$BFFF) is fixed.
 949  C000              ; DrawCharXY trampoline in bank2 jumps here.
 950  C000              ; ============================================================
 951  C000                  PAGE 7
 952  C000                  ORG $C000
 953  C000
 954  C000              DrawCharXY_Real:
 955  C000 E5               push hl
 956  C001 D5               push de
 957  C002 C5               push bc
 958  C003 DD E5            push ix
 959  C005 F5               push af
