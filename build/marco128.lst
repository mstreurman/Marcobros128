2252  C6CC C6 0E            add a, PLR_H
2253  C6CE 47               ld b, a             ; B = pixel_y (plr_y + PLR_H)
2254  C6CF
2255  C6CF                  ; Left foot: pixel_x = plr_x + 4
2256  C6CF 2A 14 80         ld hl, (plr_x)      ; HL = plr_x (16-bit) — Fix 33
2257  C6D2 11 04 00         ld de, 4
2258  C6D5 19               add hl, de          ; HL = plr_x + 4
2259  C6D6 CD 7A C6         call GetTileAt      ; BC preserved by GetTileAt (Fix 33), B still = pixel_y
2260  C6D9 CD BF C6         call IsSolid
2261  C6DC C2 EE C6         jp nz, .cg_snap
2262  C6DF
2263  C6DF                  ; Right foot: pixel_x = plr_x + PLR_W - 4
2264  C6DF                  ; B = pixel_y still valid (GetTileAt now preserves BC)
2265  C6DF 2A 14 80         ld hl, (plr_x)
2266  C6E2 11 08 00         ld de, PLR_W - 4
2267  C6E5 19               add hl, de          ; HL = plr_x + PLR_W - 4
