 865  BF7B              ; BANK SWITCH — A = bank number 0-7
 866  BF7B              ; Skips the port write if bankswitch_ok=0 (48K/SNA mode)
 867  BF7B              ; ============================================================
 868  BF7B              BankSwitch:
 869  BF7B F3               di
 870  BF7C C5               push bc
 871  BF7D F5               push af
 872  BF7E 47               ld b, a
