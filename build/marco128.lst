 234  838F              ; IM2 SETUP
 235  838F              ; ============================================================
 236  838F              Setup_IM2:
 237  838F F3               di
 238  8390 21 00 7E         ld hl, IM2_TABLE
 239  8393 06 00            ld b, 0
 240  8395 3E BC            ld a, $BC
 241  8397              .fill:
 242  8397 77               ld (hl), a
 243  8398 23               inc hl
 244  8399 10 FC            djnz .fill
 245  839B 77               ld (hl), a
 246  839C 21 BC BC         ld hl, IM2_JUMP
 247  839F 36 C3            ld (hl), $C3
 248  83A1 23               inc hl
 249  83A2 36 00            ld (hl), low HANDLER_ADDR
 250  83A4 23               inc hl
 251  83A5 36 BC            ld (hl), high HANDLER_ADDR
 252  83A7 3E 7E            ld a, $7E
 253  83A9 ED 47            ld i, a
 254  83AB ED 5E            im 2
 255  83AD FB               ei
 256  83AE C9               ret
 257  83AF
 258  83AF              ; ============================================================
 259  83AF              ; LEVEL LOAD HELPERS — must live in bank2 (fixed) because
 260  83AF              ; InitLevel calls BankSwitch which pages out bank7.
 261  83AF              ; If these were in bank7 they'd vanish mid-execution.
 262  83AF              ; ============================================================
 263  83AF
 264  83AF              SetLevelMapPtr:
 265  83AF                  ; Returns HL = $C000 + level_num * MAP_W*MAP_H
 266  83AF 21 00 C0         ld hl, $C000
 267  83B2 3A 41 80         ld a, (level_num)
 268  83B5 B7               or a
 269  83B6 C8               ret z
 270  83B7 11 C0 02         ld de, MAP_W * MAP_H
 271  83BA 19               add hl, de
 272  83BB 3D               dec a
 273  83BC C8               ret z
 274  83BD 19               add hl, de
 275  83BE C9               ret
 276  83BF
 277  83BF              LoadLevelMap:
 278  83BF                  ; Copy level map from paged bank ($C000) → level_map_cache (bank2)
 279  83BF                  ; Level bank must already be paged in.
 280  83BF CD AF 83         call SetLevelMapPtr     ; HL = map start in paged bank
 281  83C2 11 B5 80         ld de, level_map_cache
 282  83C5 01 C0 02         ld bc, MAP_W * MAP_H
 283  83C8 ED B0            ldir
 284  83CA C9               ret
 285  83CB
 286  83CB              DoLevelBanking:
 287  83CB                  ; Called from InitLevel (bank7). MUST live in bank2 (fixed).
 288  83CB                  ; Pages in the level bank, loads map + spawns to bank2 caches, restores bank7.
 289  83CB                  ; Call convention: bank number already in cur_level_bank; level_num already set.
 290  83CB                  ; (Fix 25d: recreated bank2 shim — bank7 cannot call BankSwitch directly.)
 291  83CB 3A 45 80         ld a, (cur_level_bank)
 292  83CE CD 7B BF         call BankSwitch          ; pages out bank7 — safe because we are in bank2
 293  83D1 CD BF 83         call LoadLevelMap        ; reads from paged bank into level_map_cache (bank2)
 294  83D4 CD DD 83         call LoadEnemySpawns     ; reads spawn table into entity arrays (bank2)
 295  83D7 3E 07            ld a, 7
 296  83D9 CD 7B BF         call BankSwitch          ; restore bank7
 297  83DC C9               ret
 298  83DD
 299  83DD              LoadEnemySpawns:
 300  83DD                  ; Spawn table base: $C000 + 3*MAP_W*MAP_H, then +32 per level
 301  83DD 21 40 C8         ld hl, $C000 + 3 * MAP_W * MAP_H
 302  83E0 3A 41 80         ld a, (level_num)
 303  83E3 B7               or a
 304  83E4 28 07            jr z, .les_ready
 305  83E6 11 20 00         ld de, 32
 306  83E9              .les_off:
 307  83E9 19               add hl, de
 308  83EA 3D               dec a
 309  83EB 20 FC            jr nz, .les_off
 310  83ED              .les_ready:
 311  83ED 06 08            ld b, MAX_ENEMIES
 312  83EF 0E 00            ld c, 0
 313  83F1              .les_loop:
 314  83F1 7E               ld a, (hl)
 315  83F2 FE FF            cp $FF
 316  83F4 28 4B            jr z, .les_done
 317  83F6 B7               or a
 318  83F7 28 48            jr z, .les_done
 319  83F9
 320  83F9 E5               push hl
 321  83FA 21 48 80         ld hl, ent_type
 322  83FD 16 00            ld d, 0
 323  83FF 59               ld e, c
 324  8400 19               add hl, de
 325  8401 77               ld (hl), a
 326  8402 E1               pop hl
 327  8403
 328  8403 23               inc hl
 329  8404                  ; Fix 26c: 16-bit tile_x * 16. Previous code used 8-bit ADD A,A four times;
 330  8404                  ; tile_x >= 16 (e.g. tile 24*16=384=$180) overflowed, truncating to 8 bits.
 331  8404                  ; Use HL for full 16-bit result, store low byte to ent_xl, high to ent_xh.
 332  8404 7E               ld a, (hl)          ; tile_x (0..63)
 333  8405 E5               push hl             ; save spawn table pointer
 334  8406 6F               ld l, a
 335  8407 26 00            ld h, 0             ; HL = tile_x
 336  8409 29               add hl, hl          ; *2
 337  840A 29               add hl, hl          ; *4
 338  840B 29               add hl, hl          ; *8
 339  840C 29               add hl, hl          ; *16  → pixel_x (0..1008, needs 2 bytes)
 340  840D 16 00            ld d, 0
 341  840F 59               ld e, c             ; DE = entity_index
 342  8410 C5               push bc             ; CHANGED: Fix 45 — save B=loop_counter, C=entity_index before pop bc clobbers them
 343  8411 E5               push hl             ; save pixel_x
 344  8412 21 50 80         ld hl, ent_xl
 345  8415 19               add hl, de
 346  8416 C1               pop bc              ; B = pixel_x high byte, C = pixel_x low byte
 347  8417 71               ld (hl), c          ; ent_xl[idx] = low byte
 348  8418 21 58 80         ld hl, ent_xh
 349  841B 19               add hl, de          ; DE still = entity_index (set before push bc)
 350  841C 70               ld (hl), b          ; ent_xh[idx] = high byte
 351  841D C1               pop bc              ; CHANGED: Fix 45 — restore B=loop_counter, C=entity_index
 352  841E E1               pop hl              ; restore spawn table pointer
 353  841F
 354  841F 23               inc hl
 355  8420 7E               ld a, (hl)
 356  8421 87               add a, a
 357  8422 87               add a, a
 358  8423 87               add a, a
 359  8424 87               add a, a            ; A = tile_y * 16 (pixel Y of that tile row's top)
 360  8425 D6 0E            sub PLR_H           ; CHANGED: Fix 48 — place enemy feet at tile row top: y = tile_y*16 - height
 361  8427                                      ; tile_y=9 → 144-14=130; enemy body spans y=130-143, standing on row 9 at y=144
 362  8427 E5               push hl
 363  8428 21 60 80         ld hl, ent_yl
 364  842B 16 00            ld d, 0
 365  842D 59               ld e, c             ; CHANGED: Fix 45 — C is now correctly entity_index (restored above)
 366  842E 19               add hl, de
 367  842F 77               ld (hl), a
 368  8430
 369  8430 21 70 80         ld hl, ent_vx
 370  8433 19               add hl, de
 371  8434 36 FF            ld (hl), $FF
 372  8436
 373  8436 21 78 80         ld hl, ent_state
 374  8439 19               add hl, de
 375  843A 36 01            ld (hl), 1
 376  843C E1               pop hl
 377  843D
 378  843D 23               inc hl
 379  843E 0C               inc c               ; CHANGED: Fix 45 — C is now correctly entity_index (not pixel_x_low)
 380  843F 10 B0            djnz .les_loop      ; CHANGED: Fix 45 — B is now correctly loop_counter (not pixel_x_high)
 381  8441              .les_done:
 382  8441 C9               ret
