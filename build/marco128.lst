 417  BC28 35               dec (hl)
 418  BC29              .no_timer:
 419  BC29
 420  BC29                  ; Fix 67: Corrected keyboard matrix for $DF row.
 421  BC29                  ; $DF = port $DFFE. Bit layout: bit4=Y, bit3=U, bit2=I, bit1=O, bit0=P
 422  BC29                  ; Previous code used bit4=P and bit3=O — reading Y and U instead!
 423  BC29                  ; Port $7FFE (row $7F): bit0=Space (fire/jump) — unchanged, was correct.
 424  BC29 16 00            ld d, 0                 ; CHANGED: Fix 67 — D accumulates joy_held bits
 425  BC2B
 426  BC2B 3E DF            ld a, $DF               ; CHANGED: Fix 67 — port $DFFE
 427  BC2D DB FE            in a, ($FE)
 428  BC2F CB 47            bit 0, a                ; CHANGED: Fix 67 — P key = bit0 (was bit4=Y, wrong!)
 429  BC31 20 02            jr nz, .kbd_no_p
 430  BC33 CB C2            set 0, d                ; right bit
 431  BC35              .kbd_no_p:
 432  BC35 CB 4F            bit 1, a                ; CHANGED: Fix 67 — O key = bit1 (was bit3=U, wrong!)
 433  BC37 20 02            jr nz, .kbd_no_o
 434  BC39 CB CA            set 1, d                ; left bit
 435  BC3B              .kbd_no_o:
 436  BC3B 3E 7F            ld a, $7F               ; port $7FFE: Space=bit0 (unchanged — was correct)
 437  BC3D DB FE            in a, ($FE)
 438  BC3F CB 47            bit 0, a                ; Space key (active low = fire/jump)
 439  BC41 20 02            jr nz, .kbd_no_space
 440  BC43 CB E2            set 4, d                ; fire bit
 441  BC45              .kbd_no_space:
 442  BC45 7A               ld a, d                 ; A = complete joy_held byte
 443  BC46 32 95 80         ld (joy_held), a
 444  BC49 47               ld b, a
 445  BC4A 3A 97 80         ld a, (joy_prev)
 446  BC4D 2F               cpl
 447  BC4E A0               and b
 448  BC4F 32 96 80         ld (joy_new), a
 449  BC52 3A 95 80         ld a, (joy_held)
 450  BC55 32 97 80         ld (joy_prev), a
 451  BC58
 452  BC58 3A B1 80         ld a, (music_playing)
 453  BC5B B7               or a
 454  BC5C 28 03            jr z, .no_music
 455  BC5E CD F3 BC         call Music_Tick
 456  BC61              .no_music:
 457  BC61
 458  BC61 3A A8 80         ld a, (sfx_active)
 459  BC64 B7               or a
 460  BC65 28 03            jr z, .no_sfx
 461  BC67 CD 7F BD         call SFX_Tick
 462  BC6A              .no_sfx:
 463  BC6A
 464  BC6A CD C0 BC         call AY_WriteBuffer
 465  BC6D
 466  BC6D DD E1            pop ix
 467  BC6F E1               pop hl
 468  BC70 D1               pop de
 469  BC71 C1               pop bc
 470  BC72 F1               pop af
 471  BC73                  ; Fix 26a: EI is required before RETI.
 472  BC73                  ; DI at handler entry zeros BOTH IFF1 and IFF2. RETI only copies IFF2 back
 473  BC73                  ; to IFF1 — it does NOT re-enable interrupts by itself. Without EI, after
 474  BC73                  ; the first few startup interrupts complete, IFF1 stays 0 permanently.
 475  BC73                  ; HALT then spins forever (loops as NOP with interrupts off), joy_new never
 476  BC73                  ; updates, and the title screen never exits.
 477  BC73                  ; EI immediately before RETI is the standard Z80 pattern and is safe: the
 478  BC73                  ; Z80 guarantees at least one instruction executes after EI before an
 479  BC73                  ; interrupt can be taken — RETI counts as that instruction, so there is no
 480  BC73                  ; nested-interrupt window. (Fix 25a concern is resolved: the window only
 481  BC73                  ; opens when EI and RETI are NOT adjacent.)
 482  BC73 FB               ei
 483  BC74 ED 4D            reti
 484  BC76
