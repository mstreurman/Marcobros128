 407  BC16 21 44 80         ld hl, timer_cnt
 408  BC19 34               inc (hl)
 409  BC1A 7E               ld a, (hl)
 410  BC1B FE 32            cp 50
 411  BC1D 38 0A            jr c, .no_timer
 412  BC1F 36 00            ld (hl), 0
 413  BC21 21 42 80         ld hl, level_timer
 414  BC24 7E               ld a, (hl)
 415  BC25 B7               or a
