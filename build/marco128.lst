2248  C6C9
2249  C6C9                  ; Left foot: pixel_x = plr_x + 4
2250  C6C9 2A 14 80         ld hl, (plr_x)      ; HL = plr_x (16-bit) — Fix 33
2251  C6CC 11 04 00         ld de, 4
2252  C6CF 19               add hl, de          ; HL = plr_x + 4
2253  C6D0 CD 74 C6         call GetTileAt      ; BC preserved by GetTileAt (Fix 33), B still = pixel_y
2254  C6D3 CD B9 C6         call IsSolid
2255  C6D6 C2 E8 C6         jp nz, .cg_snap
2256  C6D9
2257  C6D9                  ; Right foot: pixel_x = plr_x + PLR_W - 4
2258  C6D9                  ; B = pixel_y still valid (GetTileAt now preserves BC)
2259  C6D9 2A 14 80         ld hl, (plr_x)
2260  C6DC 11 08 00         ld de, PLR_W - 4
2261  C6DF 19               add hl, de          ; HL = plr_x + PLR_W - 4
