2547  C865
2548  C865                  ; Step 2: load 16-bit position into IX
2549  C865                  ; Note: ld ixl,(hl) is illegal on Z80 — must go via A
2550  C865 21 50 80         ld hl, ent_xl
2551  C868 16 00            ld d, 0
2552  C86A 59               ld e, c
2553  C86B 19               add hl, de
2554  C86C 7E               ld a, (hl)
