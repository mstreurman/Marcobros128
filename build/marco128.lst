2146  C674              ; ============================================================
2147  C674              ; TILE COLLISION HELPERS
2148  C674              ; ============================================================
2149  C674
2150  C674              ; GetTileAt: HL=world_pixel_x (16-bit), B=world_pixel_y → A=tile_id
2151  C674              ; Fix 33: changed from C=pixel_x (8-bit) to HL=pixel_x (16-bit) so the full
2152  C674              ; x coordinate is used. Tiles 16+ (x >= 256) were silently truncated before.
2153  C674              ; Also pushes/pops BC so caller's B (pixel_y) survives — Fix31 changed
2154  C674              ; the cache address to use BC which clobbered B, breaking cg_snap in CheckGround.
2155  C674              GetTileAt:
2156  C674                  ; Reads from level_map_cache in bank2 — no paging needed
2157  C674 E5               push hl
2158  C675 D5               push de
2159  C676 C5               push bc             ; preserve caller's B (pixel_y) — Fix 33
2160  C677
2161  C677                  ; Compute tile_x from 16-bit pixel_x in HL (0..1023):
2162  C677                  ; tile_x = pixel_x / 16 = H*16 + L/16
2163  C677 7D               ld a, l
2164  C678 0F               rrca
2165  C679 0F               rrca
2166  C67A 0F               rrca
2167  C67B 0F               rrca
2168  C67C E6 0F            and $0F             ; low 4 bits: L >> 4
2169  C67E 5F               ld e, a
2170  C67F 7C               ld a, h
2171  C680 E6 03            and $03             ; only bits[1:0] of H matter (pixel_x <= 1023)
2172  C682 07               rlca
2173  C683 07               rlca
2174  C684 07               rlca
2175  C685 07               rlca
2176  C686 E6 30            and $30             ; high 2 bits: H << 4
2177  C688 B3               or e
2178  C689 E6 3F            and $3F
2179  C68B 5F               ld e, a             ; E = tile_x (0..63)
2180  C68C
2181  C68C 78               ld a, b
2182  C68D 0F               rrca
2183  C68E 0F               rrca
2184  C68F 0F               rrca
2185  C690 0F               rrca
2186  C691 E6 0F            and $0F
2187  C693 57               ld d, a             ; tile_y (0..10)
2188  C694
2189  C694 FE 0B            cp MAP_H
2190  C696 D2 B3 C6         jp nc, .gta_solid
2191  C699 7B               ld a, e
2192  C69A FE 40            cp MAP_W
2193  C69C D2 B3 C6         jp nc, .gta_solid
2194  C69F
2195  C69F                  ; offset = tile_y * MAP_W + tile_x
2196  C69F                  ; Fix 31: was 'ld de, level_map_cache / add hl, de / ld b,0 / ld c,e'
2197  C69F                  ; but ld de overwrites E (tile_x), so ld c,e loaded $A3 (low byte of
2198  C69F                  ; level_map_cache = $80A3) instead of tile_x. Every tile lookup was
2199  C69F                  ; 161 bytes past the intended position, always past the end of the cache,
2200  C69F                  ; reading random RAM. Ground tiles never detected → player fell through
2201  C69F                  ; floor → screen_y ≥ 177 → DrawSprite wrote into attr/sysvar area → crash.
2202  C69F                  ; Fix: use ld bc / add hl,bc which preserves DE (E still = tile_x).
2203  C69F 26 00            ld h, 0
2204  C6A1 6A               ld l, d
2205  C6A2 29               add hl, hl
2206  C6A3 29               add hl, hl
2207  C6A4 29               add hl, hl
2208  C6A5 29               add hl, hl
2209  C6A6 29               add hl, hl
2210  C6A7 29               add hl, hl             ; hl = tile_y * 64  (MAP_W=64)
2211  C6A8 01 B5 80         ld bc, level_map_cache
2212  C6AB 09               add hl, bc             ; hl = level_map_cache + tile_y*64 (E still = tile_x)
2213  C6AC 06 00            ld b, 0
2214  C6AE 4B               ld c, e                ; tile_x — E intact because we used BC not DE above
2215  C6AF 09               add hl, bc
2216  C6B0 7E               ld a, (hl)
2217  C6B1 18 02            jr .gta_done
2218  C6B3
2219  C6B3              .gta_solid:
2220  C6B3 3E 01            ld a, TILE_GROUND
2221  C6B5              .gta_done:
2222  C6B5 C1               pop bc
2223  C6B6 D1               pop de
2224  C6B7 E1               pop hl
2225  C6B8 C9               ret
2226  C6B9
2227  C6B9              ; IsSolid — A=tile_id → Z=passable (AIR or FLAG), NZ=solid, A preserved
2228  C6B9              ; Fix 37: removed 'ld a,1 / or a' at end — cp TILE_FLAG already leaves Z clear
2229  C6B9              ; (NZ) for any non-FLAG solid tile, and A is preserved so CheckCeiling can
2230  C6B9              ; read the tile_id back for QBlock detection without re-calling GetTileAt.
2231  C6B9              IsSolid:
