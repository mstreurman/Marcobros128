 209  8375              ; ============================================================
 210  8375              ; ENTRY POINT  (address follows variables, after $8003)
 211  8375              ; ============================================================
 212  8375              GAME_START:
 213  8375 F3               di
 214  8376 31 FE BB         ld sp, $BBFE   ; Fix 26d: Stack in free gap ($841D-$BBFF) between LoadEnemySpawns
 215  8379                                 ; and HANDLER. Gap = 14307 bytes of DS-padded zeros, never executed.
 216  8379                                 ; Max stack depth ~128 bytes → reaches ~$BB7E, clear of code at $841C.
 217  8379                                 ; Previous $BF00 let stack reach $BEE8, inside MUSIC_OVERWORLD ($BE55).\n    ; Mark 128K paging as available (this is a 128K-only binary)
 218  8379 3E 01            ld a, 1
 219  837B 32 B4 80         ld (bankswitch_ok), a
 220  837E                  ; Fix 41: Initialise BANKM sysvar ($5B5C) to $17 = ROM1(bit4) + bank7(bits0-2).
 221  837E                  ; BankSwitch reads $5B5C, masks bits0-2, ORs in new bank, and writes the whole
 222  837E                  ; byte back to port $7FFD — so bit4 is automatically preserved on every bank
 223  837E                  ; switch as long as $5B5C is correct here.  This keeps ROM 1 (48K BASIC ROM)
 224  837E                  ; permanently paged, giving DrawCharXY_Real access to the ROM font at $3D00.
 225  837E 3E 17            ld a, $17
 226  8380 32 5C 5B         ld ($5B5C), a
 227  8383 CD 8F 83         call Setup_IM2       ; MUST run first: sets IM2 + EI so ClearScreen's
 228  8386                                       ; own EI fires into our handler, not IM0. (Fix 25c)
 229  8386 CD 9B BF         call ClearScreen
 230  8389 CD 76 BC         call AY_Silence
 231  838C C3 24 CE         jp MainLoop
 232  838F
