2568  C87F                  ; vx negative: adc IXH with $FF (= borrow propagation)
2569  C87F DD 7C            ld a, ixh
2570  C881 CE FF            adc a, $FF
2571  C883 DD 67            ld ixh, a
2572  C885 18 06            jr .uen_chk_left
