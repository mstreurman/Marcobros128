 961  C006                  ; Reject control characters (< 32)
 962  C006 D6 20            sub 32
 963  C008 DA 67 C0         jp c, .dcxy_skip        ; char < 32: nothing to draw
 964  C00B
 965  C00B                  ; A = char - 32 (range 0..223)
 966  C00B                  ; Split on original char value:
 967  C00B                  ;   char 32-127  (A  0..95): standard ASCII — ROM 1 font at $3D00
 968  C00B                  ;   char 128-255 (A 96..223): custom tiles  — FONT_DATA in bank2
 969  C00B                  ;
 970  C00B                  ; Fix 41: ROM 1 (48K BASIC ROM) is permanently paged via BANKM/BankSwitch.
 971  C00B                  ; $3D00 in ROM 1 = font bitmap for ASCII 32 (space).
 972  C00B                  ; Formula: ptr = $3D00 + (char-32)*8  =  $3D00 + A*8
 973  C00B                  ; No DI/EI or runtime page-switching needed — ROM 1 is always present.
 974  C00B                  ;
 975  C00B                  ; FONT_DATA (bank2, $8E00+) holds bitmaps for custom chars 128-255.
 976  C00B                  ; Formula: ptr = FONT_DATA + (char-128)*8  =  FONT_DATA + (A-96)*8
 977  C00B
 978  C00B FE 60            cp 96
 979  C00D 30 0F            jr nc, .dcxy_custom
 980  C00F
 981  C00F                  ; ── Standard ASCII 32-127 ── ROM 1 font ──────────────────────────────
 982  C00F 6F               ld l, a
 983  C010 26 00            ld h, 0
 984  C012 29               add hl, hl
 985  C013 29               add hl, hl
 986  C014 29               add hl, hl              ; HL = (char-32) * 8
 987  C015 11 00 3D         ld de, $3D00            ; ROM 1 font base (48K BASIC ROM)
 988  C018 19               add hl, de              ; HL = $3D00 + (char-32)*8
 989  C019 E5               push hl
 990  C01A DD E1            pop ix
 991  C01C 18 0F            jr .dcxy_draw
