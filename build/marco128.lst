 514  BCAB                  ; Fix 58: removed ay_buf[0..13] zeroing loop (14 bytes) — redundant because
 515  BCAB                  ; AY_WriteBuffer rewrites all 14 registers from ay_buf every HANDLER frame.
 516  BCAB                  ; Only ay_buf[AY_MIXER] matters: $FF keeps mixer silent on next WriteBuffer call.
 517  BCAB 3E FF            ld a, $FF               ; CHANGED: Fix 58 — keep only the mixer silent marker
 518  BCAD 32 A1 80         ld (ay_buf + AY_MIXER), a
 519  BCB0 C9               ret
 520  BCB1
 521  BCB1                  ; $BCB6-$BCBF: reserved gap for IM2 JP stub at $BCBC.
 522  BCB1                  ; Setup_IM2 and make_szx.py both write JP $BC00 at $BCBC-$BCBE.
 523  BCB1                  ; AY_WriteBuffer MUST start at $BCC0 so it is entirely past this stub.
 524  BCB1                  ; We pad here so the label naturally assembles at $BCC0.
 525  BCB1 00 00 00...      DS $BCC0 - $, 0
